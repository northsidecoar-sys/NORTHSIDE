// ── DIRECCIÓN ──────────────────────────────────────────
window.onDirInput=function(){
  clearTimeout(geoTimer);
  const v=document.getElementById('punto_encuentro').value.trim();
  if(!v){setSt('','');resetNafta();return;}
  setSt('loading','Buscando direccion...');
  geoTimer=setTimeout(()=>geocodeRoute(v),900);
};

async function geocodeRoute(dir){
  try{
    const gR=await fetch(`https://api.openrouteservice.org/geocode/search?api_key=${ORS_KEY}&text=${encodeURIComponent(dir+', Argentina')}&size=1&boundary.country=AR`);
    if(!gR.ok) throw new Error('geo_'+gR.status);
    const gD=await gR.json();
    if(!gD.features?.length){setSt('err','No se encontro la direccion. Intenta con mas detalle.');showManual();return;}
    const[lon,lat]=gD.features[0].geometry.coordinates;
    destLabel=gD.features[0].properties.label||dir;
    setSt('loading','Calculando ruta desde Nordelta...');
    const rR=await fetch(`https://api.openrouteservice.org/v2/directions/driving-car?api_key=${ORS_KEY}&start=${ORIGEN.lon},${ORIGEN.lat}&end=${lon},${lat}`);
    if(!rR.ok) throw new Error('route_'+rR.status);
    const rD=await rR.json();
    if(!rD.features?.length) throw new Error('no_route');
    const seg=rD.features[0].properties.segments[0];
    kmIda=seg.distance/1000;
    const min=Math.round(seg.duration/60);
    hideManual();
    setSt('ok',`${destLabel} — ${kmIda.toFixed(1)} km · ~${min} min`);
    recalc();
  }catch(e){
    console.warn('ORS:',e.message);
    setSt('err','No se pudo calcular la ruta. Ingresa los km manualmente.');
    showManual(); recalc();
  }
}

function showManual(){document.getElementById('manual-box').classList.add('visible');}
function hideManual(){document.getElementById('manual-box').classList.remove('visible');document.getElementById('km-manual').value='';}
window.onManualKm=function(){
  kmIda=parseFloat(document.getElementById('km-manual').value)||0;
  destLabel=document.getElementById('punto_encuentro').value||'Destino manual';
  if(kmIda>0) recalc(); else resetNafta();
};

function recalc(){
  if(kmIda<=0){resetNafta();return;}
  const p=parseFloat(document.getElementById('precio_nafta').value)||0;
  if(!p) return;
  const v=VEHS[vehAct], tot=kmIda*2, lit=tot/v.km;
  nafta$=lit*p;
  document.getElementById('nafta-placeholder').style.display='none';
  document.getElementById('nafta-detail').style.display='flex';
  document.getElementById('nd-dest').textContent=destLabel;
  document.getElementById('nd-ida').textContent=kmIda.toFixed(1)+' km';
  document.getElementById('nd-tot').textContent=tot.toFixed(1)+' km';
  document.getElementById('nd-veh').textContent=v.n+' · '+v.km+' km/L';
  document.getElementById('nd-lit').textContent=lit.toFixed(2)+' L';
  document.getElementById('nd-cos').textContent=fmt(nafta$);
  updRes();
}

function resetNafta(){
  kmIda=0;nafta$=0;destLabel='';
  document.getElementById('nafta-detail').style.display='none';
  document.getElementById('nafta-placeholder').style.display='flex';
  updRes();
}

function setSt(t,m){
  const el=document.getElementById('st-bar');
