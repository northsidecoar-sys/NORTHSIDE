// ── RESUMEN ────────────────────────────────────────────
function updRes(){
  let tv=0,tc=0;
  document.querySelectorAll('.product-row').forEach(r=>{
    const id=r.id.split('-')[1];
    tv+=parseFloat(document.getElementById(`ve-${id}`)?.value)||0;
    tc+=parseFloat(document.getElementById(`co-${id}`)?.value)||0;
  });
  const g=tv-tc, ext=parseFloat(document.getElementById('extra').value)||0, neto=g-nafta$-ext;
  document.getElementById('r-venta').textContent=fmt(tv);
  document.getElementById('r-costo').textContent=fmt(tc);
  document.getElementById('r-gan').textContent=fmt(g);
  document.getElementById('r-nafta').textContent=fmt(nafta$);
  const ne=document.getElementById('r-neto');
  ne.textContent=fmt(neto); ne.className='stat-value '+(neto>=0?'sv-pos':'sv-neg');
}

// ── GUARDAR EN FIREBASE ────────────────────────────────
window.save=function(){
  const cli=document.getElementById('cliente').value.trim();
  if(!cli){toast('⚠️ Ingresa el nombre del cliente','err');return;}
  const productos=[];
  document.querySelectorAll('.product-row').forEach(r=>{
    const id=r.id.split('-')[1];
    const idx=parseInt(r.querySelector('select').value);
    if(isNaN(idx)) return;
    productos.push({n:PRODS[idx].n, tl:document.getElementById(`tl-${id}`).value,
      cl:document.getElementById(`cl-${id}`).value,
      co:parseFloat(document.getElementById(`co-${id}`).value)||0,
      ve:parseFloat(document.getElementById(`ve-${id}`).value)||0});
  });
  if(!productos.length){toast('⚠️ Agrega al menos un producto','err');return;}

  const tv=productos.reduce((s,p)=>s+p.ve,0), tc=productos.reduce((s,p)=>s+p.co,0);
  const g=tv-tc, ext=parseFloat(document.getElementById('extra').value)||0;
  const venta={
    ts: Date.now(),
    fecha: new Date().toLocaleDateString('es-AR'),
    cli, productos,
    punto: document.getElementById('punto_encuentro').value,
    dest: destLabel, veh: VEHS[vehAct].n, kmIda: +kmIda.toFixed(1),
    nafta: nafta$, ext, tv, tc, g, neto: g-nafta$-ext,
    notas: document.getElementById('notas').value
  };

  // Limpiar y navegar ANTES de esperar Firebase (optimistic UI)
  clearForm();
  showTab('historial');
  toastOk('✓ Venta guardada');
  setSyncStatus('syncing');

  // Guardar en segundo plano sin bloquear la UI
  addDoc(collection(db,'ventas'), venta)
    .then(()=>{ setSyncStatus('online'); })
    .catch(e=>{ console.error(e); toast('Error al sincronizar','err'); setSyncStatus('online'); });
};

