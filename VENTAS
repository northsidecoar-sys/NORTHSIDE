// ── RENDER HISTORIAL ───────────────────────────────────
window.togglePago=function(id, pagada){
  // Optimista: re-render inmediato
  const v = hist.find(h=>h._id===id);
  if(v) v.pagada = pagada;
  renderConfirm();
  actualizarTotales();
  // Guardar en Firebase
  updateDoc(doc(db,'ventas',id), {pagada})
    .catch(e=>{ console.error(e); toast('Error al actualizar','err'); });
};

function renderConfirm(){
  const el = document.getElementById('confirm-cards');
  if(!hist.length){
    el.innerHTML='<div class="empty-msg">No hay ventas todavia.<br>Carga una desde + Nueva Venta</div>';
    return;
  }
  // Separar pagadas y pendientes
  const pendientes = hist.filter(v=>!v.pagada);
  const pagadas    = hist.filter(v=>v.pagada);

  function cardConf(v){
    const pr = v.productos.map(p=>p.n).join(', ');
    const nc = v.neto>=0?'sv-pos':'sv-neg';
    const esPagada = !!v.pagada;
    return `<div class="ccard ${esPagada?'pagada':'pendiente'}" id="cc-${v._id}">
      <div class="ccard-top">
        <div class="ccard-info">
          <div class="cn">${v.cli}</div>
          <div class="cd">${v.fecha}</div>
          <div class="cp">${pr}</div>
        </div>
        <div style="display:flex;flex-direction:column;align-items:flex-end;gap:8px">
          <div class="toggle-pago">
            <button class="toggle-btn ${!esPagada?'active-pend':''}" onclick="togglePago('${v._id}',false)">⏳ Pendiente</button>
            <button class="toggle-btn ${esPagada?'active-pag':''}" onclick="togglePago('${v._id}',true)">✓ Pagada</button>
          </div>
        </div>
      </div>
      <div style="display:flex;justify-content:space-between;padding:8px 0;border-top:1px solid var(--border);margin-top:4px;font-size:0.82rem">
        <span style="color:var(--muted)">Total a cobrar</span>
        <span style="color:var(--accent);font-family:'Syne',sans-serif;font-weight:700;font-size:1rem">${fmt(v.tv)}</span>
      </div>
      <div style="display:flex;justify-content:space-between;padding:8px 0;border-top:1px solid var(--border);font-size:0.82rem">
        <span style="color:var(--muted)">Neto (ganancia)</span>
        <span class="${nc}" style="font-family:'Syne',sans-serif;font-weight:700;font-size:1rem">${fmt(v.neto)}</span>
      </div>
    </div>`;
  }

  let html = '';
  if(pendientes.length){
    html += `<div style="font-family:'Syne',sans-serif;font-size:0.7rem;letter-spacing:2px;text-transform:uppercase;color:var(--warning);margin-bottom:10px">⏳ Pendientes (${pendientes.length})</div>`;
    html += pendientes.map(cardConf).join('');
  }
  if(pagadas.length){
    html += `<div style="font-family:'Syne',sans-serif;font-size:0.7rem;letter-spacing:2px;text-transform:uppercase;color:var(--success);margin:${pendientes.length?'20px':0} 0 10px">✓ Pagadas (${pagadas.length})</div>`;
    html += pagadas.map(cardConf).join('');
  }
  el.innerHTML = html;
}

function renderHist(){
  document.getElementById('hbadge').textContent=hist.length;
  renderConfirm();
  actualizarTotales();

  if(!hist.length){
    document.getElementById('hcards').innerHTML='<div class="empty-msg">No hay ventas registradas aun.<br>Carga la primera desde + Nueva Venta</div>';
    actualizarTotales(); return;
  }

  document.getElementById('hcards').innerHTML=hist.map((v)=>{
    const pr=v.productos.map(p=>`${p.n}${p.tl?' ('+p.tl+')':''}`).join(' · ');
    const nc=v.neto>=0?'pos':'neg';
    return `<div class="hcard">
      <div class="hcard-header">
        <div>
          <div class="hcard-name">${v.cli}</div>
          <div class="hcard-date">${v.fecha}</div>
        </div>
        <button class="hcard-del" onclick="delVenta('${v._id}')">✕ Borrar</button>
      </div>
      <div class="hcard-prods">${pr}</div>
      ${v.punto?`<div class="hcard-row"><span class="k">📍</span><span style="color:var(--text);font-size:0.78rem;text-align:right;max-width:70%">${v.punto}</span></div>`:''}
      ${v.kmIda?`<div class="hcard-row"><span class="k">🚗 ${v.veh}</span><span style="color:var(--accent3)">${v.kmIda} km ida</span></div>`:''}
      <div class="hcard-row"><span class="k">Venta total</span><span style="color:var(--accent)">${fmt(v.tv)}</span></div>
      <div class="hcard-row"><span class="k">Ganancia bruta</span><span style="color:var(--success)">${fmt(v.g)}</span></div>
      ${v.nafta?`<div class="hcard-row"><span class="k">Nafta</span><span style="color:var(--accent2)">${fmt(v.nafta)}</span></div>`:''}
      ${v.ext?`<div class="hcard-row"><span class="k">Extra</span><span>${fmt(v.ext)}</span></div>`:''}
      ${v.notas?`<div class="hcard-row"><span class="k">Nota</span><span style="color:var(--muted);font-size:0.75rem">${v.notas}</span></div>`:''}
      <div class="hcard-neto ${nc}">
        <span class="k">NETO FINAL</span>
        <span class="v">${fmt(v.neto)}</span>
      </div>
    </div>`;
  }).join('');

  actualizarTotales();
}

function actualizarTotales(){
  const pagadas = hist.filter(v=>v.pagada);
  const pendientes = hist.filter(v=>!v.pagada);
  const s=k=>pagadas.reduce((a,v)=>a+(v[k]||0),0);
  document.getElementById('t-venta').textContent=fmt(s('tv'));
  document.getElementById('t-gan').textContent=fmt(s('g'));
  document.getElementById('t-nafta').textContent=fmt(s('nafta'));
  document.getElementById('t-cant').textContent=pagadas.length+' pagadas / '+pendientes.length+' pendientes';
  const tn=s('neto'), te=document.getElementById('t-neto');
  te.textContent=fmt(tn); te.className='stat-value '+(tn>=0?'sv-pos':'sv-neg');
  // Subtitulo en resumen
  const sub=document.getElementById('resumen-sub');
  if(sub) sub.textContent='Solo ventas pagadas ('+pagadas.length+' de '+hist.length+')';
}

// ── LIMPIAR FORM ───────────────────────────────────────
window.clearForm=function(){
  ['cliente','punto_encuentro','extra','notas'].forEach(i=>document.getElementById(i).value='');
  setSt('',''); hideManual(); resetNafta();
  document.getElementById('prod-lista').innerHTML='';
  pCount=0; addProd(); updRes();
  // Asegurarse que el boton guardar siempre quede habilitado
  const b=document.querySelector('#pane-nueva .btn-primary');
  if(b){b.disabled=false;b.textContent='✓ Guardar Venta';b.style.opacity='1';}
};

// ── UTILS ──────────────────────────────────────────────
function fmt(n){return '$'+Math.round(n).toLocaleString('es-AR');}
function toast(m,tipo){
  const el=document.getElementById('notif');
  el.textContent=m;
  el.style.borderColor=tipo==='err'?'var(--accent2)':'var(--accent)';
  el.style.display='block';
  clearTimeout(window._toastTimer);
  window._toastTimer=setTimeout(()=>el.style.display='none',3000);
}
function toastOk(m){
  // Toast grande de exito en el centro de la pantalla
  const el=document.getElementById('toast-ok');
  el.textContent=m;
  el.style.display='flex';
  clearTimeout(window._toastOkTimer);
  window._toastOkTimer=setTimeout(()=>el.style.display='none',2500);
}

// INIT
addProd();

</script>
